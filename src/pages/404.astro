---
import '@/styles/global.css'
---

<!doctype html>
<html lang="tr" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex,nofollow" />
    <title>404 | DevrimSoft</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="flex min-h-screen flex-col items-center justify-center bg-white text-navy-900 antialiased">
    <div class="mx-auto max-w-lg px-6 text-center">
      <div class="mb-8">
        <a href="/tr/" aria-label="DevrimSoft">
          <img src="/logo.svg" alt="DevrimSoft" class="mx-auto h-10" />
        </a>
      </div>

      <p class="mb-2 text-7xl font-bold text-accent-500" style="font-family: 'Space Grotesk', system-ui, sans-serif;">404</p>
      <h1 class="mb-4 text-2xl font-semibold text-navy-900">Sayfa Bulunamadi</h1>
      <p class="mb-8 text-navy-500">Aradiginiz sayfa mevcut degil veya tasindi.</p>

      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/tr/"
          class="inline-flex items-center gap-2 rounded-xl bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-600"
        >
          <i class="fas fa-home text-xs"></i>
          Ana Sayfa
        </a>
        <a
          href="/en/"
          class="inline-flex items-center gap-2 rounded-xl border border-navy-200 px-6 py-3 text-sm font-semibold text-navy-700 transition-colors hover:border-accent-500 hover:text-accent-500"
        >
          English
        </a>
      </div>
    </div>
  </body>
</html>
