---
import type { Locale } from '@/i18n/locales'
import { useTranslations } from '@/i18n/utils'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)

const rotatingWords = [
  t('hero.rotate.1'),
  t('hero.rotate.2'),
  t('hero.rotate.3'),
  t('hero.rotate.4'),
  t('hero.rotate.5'),
  t('hero.rotate.6'),
  t('hero.rotate.1'),
]

const techStack = [
  { icon: 'fab fa-react', label: 'React' },
  { icon: 'fab fa-golang', label: 'Go' },
  { icon: 'fab fa-php', label: 'PHP' },
  { icon: 'fab fa-rust', label: 'Rust' },
  { icon: 'fab fa-python', label: 'Python' },
  { icon: 'fab fa-node-js', label: 'Node.js' },
  { icon: 'fas fa-n', label: 'Next.js' },
  { icon: 'fas fa-database', label: 'PostgreSQL' },
  { icon: 'fab fa-docker', label: 'Docker' },
  { icon: 'fas fa-cloud', label: 'Cloud' },
  { icon: 'fas fa-shield-halved', label: 'Security' },
]
---

<section id="hero" class="relative overflow-hidden bg-white">
  <!-- Subtle background decoration -->
  <div class="absolute inset-0">
    <div class="mesh-gradient absolute -left-20 bottom-1/4 h-[500px] w-[500px] bg-accent-500/5"></div>
    <div class="mesh-gradient absolute right-0 top-0 h-72 w-72 bg-navy-200/10" style="animation-delay: -7s;"></div>
    <div class="mesh-gradient absolute left-1/3 top-0 h-48 w-48 bg-accent-400/5" style="animation-delay: -14s;"></div>
  </div>

  <!-- Subtle dot grid -->
  <div class="absolute inset-0 text-navy-900/[0.03] dot-pattern"></div>

  <div class="container-wide relative py-16 sm:py-32 lg:py-40">
    <div class="grid items-center gap-10 sm:gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left side — Content -->
      <div>
        <!-- Heading -->
        <h1 class="font-display text-[2rem] font-bold leading-[1.15] tracking-tight text-navy-900 sm:text-5xl lg:text-6xl xl:text-7xl">
          {t('hero.title')}
          <br />
          <span class="gradient-text">{t('hero.titleHighlight')}</span>
        </h1>

        <!-- Rotating text -->
        <div class="mt-4 flex items-center gap-2 text-base text-navy-500 sm:mt-6 sm:text-xl lg:text-2xl">
          <div class="text-rotator font-display font-semibold text-accent-600">
            {rotatingWords.map((word) => (
              <span>{word}</span>
            ))}
          </div>
        </div>

        <!-- Subtitle -->
        <p class="mt-4 max-w-xl text-sm leading-relaxed text-navy-600 sm:mt-6 sm:text-lg">
          {t('hero.subtitle')}
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-col gap-3 sm:mt-10 sm:flex-row sm:gap-4">
          <a href="#portfolio" class="btn-accent px-6 py-3.5 text-sm sm:px-8 sm:py-4 sm:text-base">
            <i class="fas fa-briefcase text-xs sm:text-sm"></i>
            {t('hero.cta')}
          </a>
          <a href="#contact" class="btn-ghost px-6 py-3.5 text-sm sm:px-8 sm:py-4 sm:text-base">
            <i class="fas fa-paper-plane text-xs sm:text-sm"></i>
            {t('hero.ctaSecondary')}
          </a>
        </div>

        <!-- TEKMER Badge -->
        <a href="https://alanyatekmer.com/firma/1" target="_blank" rel="noopener noreferrer" class="group mt-6 inline-flex items-center gap-2.5 rounded-xl border border-navy-200 bg-navy-50/50 px-4 py-2.5 transition-all duration-300 hover:border-accent-500/40 hover:bg-accent-50 sm:mt-8 sm:gap-3 sm:px-5 sm:py-3">
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-accent-500/10 transition-colors group-hover:bg-accent-500/20 sm:h-8 sm:w-8">
            <i class="fas fa-building-columns text-xs text-accent-500 sm:text-sm"></i>
          </div>
          <span class="text-xs font-medium text-navy-700 transition-colors group-hover:text-accent-600 sm:text-sm">{t('hero.tekmer')}</span>
          <i class="fas fa-arrow-up-right-from-square text-[10px] text-navy-400 transition-colors group-hover:text-accent-500"></i>
        </a>
      </div>

      <!-- Right side — Partners -->
      <div class="flex flex-col items-center justify-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-navy-200 bg-navy-50 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-navy-600 sm:mb-4 sm:px-4 sm:text-xs lg:mb-6">
          <i class="fas fa-handshake text-accent-500"></i>
          {t('hero.partners')}
        </div>
        <div class="grid grid-cols-3 gap-2.5 sm:gap-4 lg:gap-5">
          {[
            { logo: 'https://view.devrimsoft.com/tekmer/static/d0f269d3_logo.webp', url: 'https://alanyatekmer.com', name: 'Alanya TEKMER' },
            { logo: 'https://view.devrimsoft.com/devrimsoft/beyzick-logo%20(1).svg', url: 'https://beyzick.com', name: 'Beyzick' },
            { logo: 'https://view.devrimsoft.com/devrimsoft/antarge.webp', url: 'https://antargetech.com', name: 'Antarge Tech' },
            { logo: 'https://view.devrimsoft.com/devrimsoft/cropped-1.png', url: 'https://goktas.net', name: 'Goktas' },
            { logo: 'https://view.devrimsoft.com/devrimsoft/logo.webp', url: 'https://zsoftrade.com', name: 'ZSoftrade' },
            { logo: 'https://view.devrimsoft.com/devrimsoft/sadelogo.png', url: 'https://oksijen.co', name: 'Oksijen' },
          ].map((partner) => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col items-center justify-center gap-1.5 rounded-xl border border-navy-100 bg-white px-2 py-4 shadow-sm transition-all duration-300 hover:border-accent-500/40 hover:shadow-lg hover:shadow-accent-500/10 hover:-translate-y-1 sm:rounded-2xl sm:gap-2 sm:p-4 lg:p-5"
              aria-label={partner.name}
            >
              <img
                src={partner.logo}
                alt={partner.name}
                class="max-h-7 w-full object-contain opacity-70 transition-all duration-300 group-hover:opacity-100 sm:max-h-12 lg:max-h-16"
                loading="lazy"
              />
              <span class="line-clamp-1 text-center text-[9px] font-medium text-navy-400 sm:hidden">{partner.name}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Tech stack badges — wrap on mobile -->
    <div class="mt-10 sm:mt-16 lg:mt-20">
      <div class="flex flex-wrap justify-center gap-2 lg:justify-start">
        {techStack.map((tech) => (
          <div class="flex items-center gap-2 rounded-lg border border-navy-200 bg-navy-50/50 px-3 py-2 transition-all duration-200 hover:border-navy-300 hover:bg-navy-50 sm:px-4 sm:py-2.5">
            <i class:list={[tech.icon, 'text-sm text-navy-500']}></i>
            <span class="whitespace-nowrap text-xs font-medium text-navy-600 sm:text-sm">{tech.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
