  {/* ════════════════════════════════════════════════ */}
  {/* ABOUT — Vision, Mission, Story, Stats, Values   */}
  {/* ════════════════════════════════════════════════ */}
  <section id="about" class="scroll-mt-16 sm:scroll-mt-20">
    <!-- Vision & Mission — Editorial style -->
    <div class="section-padding bg-white">
      <div class="container-wide">
        <VisionMission lang={lang} />
      </div>
    </div>

    <!-- Story — Blockquote style with decorative quote -->
    <div class="py-10 bg-gradient-to-b from-white to-navy-50/30 sm:py-16">
      <div class="container-wide">
        <div class="mx-auto max-w-4xl">
          <div class="relative rounded-2xl border border-navy-100 bg-white p-6 sm:p-10 lg:p-14">
            <!-- Decorative quote mark -->
            <div class="absolute -top-4 left-6 flex h-8 w-8 items-center justify-center rounded-lg bg-accent-500 text-white shadow-lg sm:-top-5 sm:left-8 sm:h-10 sm:w-10 sm:rounded-xl">
              <i class="fas fa-quote-left text-xs sm:text-sm"></i>
            </div>

