  {/* ════════════════════════════════════════════════ */}
  {/* PORTFOLIO — Featured + Grid Hybrid              */}
  {/* ════════════════════════════════════════════════ */}
  <section id="portfolio" class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-navy-200 bg-navy-50 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-navy-600 sm:mb-4 sm:px-4 sm:text-xs">
          <i class="fas fa-briefcase text-accent-500"></i>
          {t('portfolio.title')}
        </div>
        <h2 class="heading-2 text-navy-900">{t('portfolio.title')}</h2>
        <p class="mx-auto mt-3 max-w-2xl text-base text-navy-600 sm:mt-4 sm:text-lg">{t('portfolio.subtitle')}</p>
      </div>

      <!-- Projects -->
      <div class="mx-auto mt-8 grid gap-5 sm:mt-12 sm:gap-8 lg:grid-cols-2">
        {projects.map((project) => (
          <article class="group relative overflow-hidden rounded-2xl border border-navy-100 bg-white p-5 transition-all duration-300 hover:border-navy-200 hover:shadow-2xl hover:shadow-navy-100/50 hover:-translate-y-1 sm:p-8">
            <!-- Top row: icon + meta -->
            <div class="flex items-start gap-4 sm:gap-5">
              <div class={`flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br ${project.gradient} text-white shadow-lg transition-transform duration-300 group-hover:scale-110 sm:h-14 sm:w-14`}>
                <i class:list={[project.icon, 'text-lg sm:text-xl']}></i>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center gap-1.5 text-xs text-navy-500">
                    <i class="fas fa-building text-[10px] text-navy-400"></i>
                    {t(project.clientKey)}
                  </span>
                  <span class="h-3.5 w-px bg-navy-200"></span>
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-navy-50 px-2.5 py-0.5 text-[11px] font-medium text-navy-600">
                    <i class="far fa-calendar text-[10px]"></i>
                    {project.month}/{project.year}
                  </span>
                </div>
                <h3 class="mt-2 font-display text-lg font-bold text-navy-900 transition-colors group-hover:text-accent-600 sm:text-xl">
                  {t(project.titleKey)}
                </h3>
              </div>
            </div>

            <!-- Description -->
            <p class="mt-4 text-sm leading-relaxed text-navy-600">
              {t(project.descKey)}
            </p>

            <!-- Tech tags -->
            <div class="mt-4 flex flex-wrap gap-1.5 sm:mt-5">
              {project.technologies.map((tech) => (
                <span class="rounded-lg bg-navy-50 px-2.5 py-1 text-xs font-medium text-navy-700">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Visit link -->
            {project.url && (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 rounded-lg border border-navy-200 px-3 py-2 text-[11px] font-semibold text-navy-700 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white sm:mt-6 sm:px-4 sm:text-xs">
                <i class="fas fa-arrow-up-right-from-square text-[10px]"></i>
                {t('portfolio.visitSite')}
              </a>
            )}

            <!-- Hover accent line -->
            <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-gradient-to-r from-accent-400 to-accent-600 transition-all duration-500 group-hover:w-full"></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ════════════════════════════════════════════════ */}
  {/* CERTIFICATIONS — Timeline Layout                */}
  {/* ════════════════════════════════════════════════ */}
  <section id="certifications" class="section-padding bg-navy-50/30">
    <div class="container-wide">
      <div class="text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-navy-200 bg-white px-3 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-navy-600 sm:mb-4 sm:px-4 sm:text-xs">
          <i class="fas fa-certificate text-accent-500"></i>
          {t('certs.title')}
        </div>
        <h2 class="heading-2 text-navy-900">{t('certs.title')}</h2>
        <p class="mx-auto mt-3 max-w-2xl text-base text-navy-600 sm:mt-4 sm:text-lg">{t('certs.subtitle')}</p>
      </div>

      <!-- Timeline -->
      <div class="relative mx-auto mt-8 max-w-4xl sm:mt-16">
        <!-- Vertical timeline line (desktop only) -->
        <div class="timeline-line hidden lg:block"></div>

        <div class="space-y-5 sm:space-y-8 lg:space-y-16">
          {certifications.map((cert, idx) => (
            <div class="relative grid items-start gap-8 lg:grid-cols-2">
              {/* Date + Issuer side — desktop only */}
              <div class:list={[
                'hidden lg:flex flex-col gap-3',
                idx % 2 === 0 ? 'lg:text-right lg:pr-12' : 'lg:order-last lg:pl-12',
              ]}>
                <span class:list={[
                  'inline-flex items-center gap-1.5 text-sm font-medium text-navy-500',
                  idx % 2 === 0 ? 'lg:justify-end' : 'lg:justify-start',
                ]}>
                  <i class="far fa-calendar text-xs"></i>
                  {t(cert.dateKey)}
                </span>
                <span class:list={[
                  'inline-flex w-fit items-center gap-1.5 rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700',
                  idx % 2 === 0 ? 'lg:ml-auto' : '',
                ]}>
                  <i class="fas fa-award text-[10px] text-accent-500"></i>
                  {cert.issuer}
                </span>
                <span class:list={[
                  'inline-flex w-fit items-center gap-1.5 text-xs text-navy-400',
                  idx % 2 === 0 ? 'lg:ml-auto' : '',
                ]}>
                  <i class="fas fa-user text-[10px]"></i>
                  Devran Tuncer
                </span>
              </div>

              {/* Timeline dot (desktop only) */}
              <div class:list={['timeline-dot hidden lg:block', cert.color]} style="top: 12px;"></div>

              {/* Content card */}
              <div class:list={[
                idx % 2 === 0 ? 'lg:pl-12' : 'lg:order-first lg:pr-12',
              ]}>
                <article class="group relative overflow-hidden rounded-2xl border border-navy-100 bg-white p-5 transition-all duration-300 hover:border-navy-200 hover:shadow-xl hover:shadow-navy-100/50 sm:p-6 lg:p-8">
                  {/* Mobile: integrated metadata bar */}
                  <div class="mb-3 flex flex-wrap items-center gap-2 lg:hidden sm:mb-4">
                    <span class="inline-flex items-center gap-1.5 text-xs font-medium text-navy-500">
                      <i class="far fa-calendar text-[10px]"></i>
                      {t(cert.dateKey)}
                    </span>
                    <span class="h-3.5 w-px bg-navy-200"></span>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-navy-50 px-2.5 py-0.5 text-[11px] font-semibold text-navy-700">
                      <i class="fas fa-award text-[9px] text-accent-500"></i>
                      {cert.issuer}
                    </span>
                    <span class="h-3.5 w-px bg-navy-200"></span>
                    <span class="inline-flex items-center gap-1.5 text-[11px] text-navy-400">
                      <i class="fas fa-user text-[9px]"></i>
                      Devran Tuncer
                    </span>
                  </div>

                  <div class="flex items-start gap-3 sm:gap-4">
                    <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br ${cert.gradient} text-white shadow-sm sm:h-12 sm:w-12`}>
                      <i class:list={[cert.icon, 'text-base sm:text-lg']}></i>
                    </div>
                    <div class="min-w-0 flex-1">
                      <h3 class="font-display text-base font-bold text-navy-900 transition-colors group-hover:text-accent-600 sm:text-lg">
                        {t(cert.titleKey)}
                      </h3>
                      <p class="mt-1.5 text-sm leading-relaxed text-navy-600 sm:mt-2">
                        {t(cert.descKey)}
                      </p>

                      {/* Skills tags */}
                      <div class="mt-3 sm:mt-4">
                        <p class="mb-1.5 text-[11px] font-semibold uppercase tracking-wider text-navy-400 sm:mb-2 sm:text-xs">{t('certs.skills')}</p>
                        <div class="flex flex-wrap gap-1 sm:gap-1.5">
                          {cert.skills.map((skill) => (
                            <span class="rounded-md bg-navy-50 px-2 py-0.5 text-[10px] font-medium text-navy-600 sm:rounded-lg sm:px-2.5 sm:py-1 sm:text-[11px]">
                              {skill}
                            </span>
                          ))}
                        </div>
                      </div>

                      {/* Verify link */}
                      <a
                        href={cert.credlyUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mt-3 inline-flex items-center gap-2 rounded-lg border border-navy-200 px-3 py-1.5 text-[11px] font-semibold text-navy-700 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white sm:mt-4 sm:px-4 sm:py-2 sm:text-xs"
                      >
                        <i class="fas fa-arrow-up-right-from-square text-[10px]"></i>
                        {t('certs.verify')} — Credly
                      </a>
                    </div>
                  </div>

                  <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-gradient-to-r from-accent-400 to-accent-600 transition-all duration-500 group-hover:w-full"></div>
                </article>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ════════════════════════════════════════════════ */}
  {/* CONTACT — Modern Layout                         */}
  {/* ════════════════════════════════════════════════ */}
  <section id="contact" class="section-padding relative bg-gradient-to-b from-white to-navy-50/20">
    <div class="container-wide">
      <div class="text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-navy-200 bg-navy-50 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-navy-600 sm:mb-4 sm:px-4 sm:text-xs">
          <i class="fas fa-envelope text-accent-500"></i>
          {t('contact.title')}
        </div>
        <h2 class="heading-2 text-navy-900">{t('contact.title')}</h2>
        <p class="mx-auto mt-3 max-w-2xl text-base text-navy-600 sm:mt-4 sm:text-lg">{t('contact.subtitle')}</p>
      </div>

      <!-- Contact Info + Social -->
      <div class="mx-auto mt-8 max-w-3xl sm:mt-14">
        <div class="grid gap-3 sm:grid-cols-2 sm:gap-4">
          {contactInfo.map((info) => (
            <div class="group flex items-center gap-3 rounded-xl border border-navy-100 bg-white p-4 transition-all duration-200 hover:border-navy-200 hover:shadow-md sm:gap-4 sm:p-5">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-navy-50 transition-colors group-hover:bg-accent-500/10 sm:h-11 sm:w-11">
                <i class:list={[info.icon, 'text-sm text-navy-500 transition-colors group-hover:text-accent-500']}></i>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-[11px] text-navy-400 sm:text-xs">{info.label}</p>
                {info.href ? (
                  <a href={info.href} target={info.href.startsWith('http') ? '_blank' : undefined} rel={info.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="block truncate text-sm font-semibold text-navy-800 transition-colors hover:text-accent-600">
                    {info.value}
                  </a>
                ) : (
                  <div class="truncate text-sm font-semibold text-navy-800">{info.value}</div>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Social -->
        <div class="mt-6 flex items-center justify-center gap-2.5 sm:mt-8 sm:gap-3">
          <a href="https://github.com/devrim-1283" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-xl border border-navy-200 text-navy-500 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white" aria-label="GitHub">
            <i class="fab fa-github text-lg"></i>
          </a>
          <a href="https://www.linkedin.com/company/110658134/" target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 items-center justify-center rounded-xl border border-navy-200 text-navy-500 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white" aria-label="LinkedIn">
            <i class="fab fa-linkedin-in text-lg"></i>
          </a>
        </div>
      </div>

      <!-- Office Locations with Maps -->
      <div class="mt-8 sm:mt-16">
        <div class="mb-5 text-center sm:mb-8">
          <h3 class="font-display text-base font-bold text-navy-900 sm:text-xl">{t('contact.offices.title')}</h3>
        </div>
        <div class="grid gap-4 sm:gap-8 md:grid-cols-2">
          <!-- Antalya Office -->
          <div class="overflow-hidden rounded-2xl border border-navy-100 bg-white">
            <div class="p-4 sm:p-6">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-accent-500 to-amber-600 text-white sm:h-10 sm:w-10">
                  <i class="fas fa-location-dot text-xs sm:text-sm"></i>
                </div>
                <div>
                  <h4 class="font-display text-sm font-bold text-navy-900 sm:text-base">{t('contact.offices.antalya.title')}</h4>
                  <p class="text-[11px] text-navy-500 sm:text-xs">{t('contact.offices.antalya.desc')}</p>
                </div>
              </div>
            </div>
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3206.1384089900225!2d32.08277081192241!3d36.52665507221093!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14dc9bb327c9f08d%3A0x6195c04f9208f83b!2sDevrimSoft!5e0!3m2!1str!2str!4v1772534316158!5m2!1str!2str"
              class="h-40 w-full border-0 sm:h-56"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="DevrimSoft Antalya Office"
            ></iframe>
          </div>

          <!-- Istanbul Office -->
          <div class="overflow-hidden rounded-2xl border border-navy-100 bg-white">
            <div class="p-4 sm:p-6">
              <div class="flex items-center gap-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 text-white sm:h-10 sm:w-10">
                  <i class="fas fa-location-dot text-xs sm:text-sm"></i>
                </div>
                <div>
                  <h4 class="font-display text-sm font-bold text-navy-900 sm:text-base">{t('contact.offices.istanbul.title')}</h4>
                  <p class="text-[11px] text-navy-500 sm:text-xs">{t('contact.offices.istanbul.desc')}</p>
                </div>
              </div>
            </div>
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3009.5212060029003!2d28.693692112107016!3d41.03572987122719!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa74c167d5e81%3A0xfa87d2afa1947ce6!2sDevrimSoft!5e0!3m2!1str!2str!4v1772534334435!5m2!1str!2str"
              class="h-40 w-full border-0 sm:h-56"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="DevrimSoft Istanbul Office"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

