            <p class="mt-4 text-base leading-relaxed text-navy-600 sm:mt-6 sm:text-lg">
              {t('about.story.text')}
            </p>

            <!-- Tax Certificate -->
            <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50/50 p-4 sm:mt-8 sm:p-5">
