            {/* Why use it */}
            <div class="mt-6 sm:mt-8">
              <h4 class="mb-3 text-sm font-bold text-navy-900 sm:mb-4 sm:text-base">{t('products.r2.whyTitle')}</h4>
              <ul class="space-y-2.5 sm:space-y-3">
                <li class="flex items-start gap-2.5">
                  <i class="fas fa-check-circle mt-0.5 text-xs text-emerald-500"></i>
                  <span class="text-xs leading-relaxed text-navy-600 sm:text-sm">{t('products.r2.why1')}</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <i class="fas fa-check-circle mt-0.5 text-xs text-emerald-500"></i>
                  <span class="text-xs leading-relaxed text-navy-600 sm:text-sm">{t('products.r2.why2')}</span>
                </li>
                <li class="flex items-start gap-2.5">
                  <i class="fas fa-check-circle mt-0.5 text-xs text-emerald-500"></i>
                  <span class="text-xs leading-relaxed text-navy-600 sm:text-sm">{t('products.r2.why3')}</span>
                </li>
              </ul>
            </div>

            {/* Setup service notice + CTA */}
            <div class="mt-6 flex flex-col gap-4 rounded-xl border border-accent-200 bg-accent-50/50 p-4 sm:mt-8 sm:flex-row sm:items-center sm:justify-between sm:p-5">
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-accent-500/10 sm:h-10 sm:w-10">
                  <i class="fas fa-screwdriver-wrench text-sm text-accent-600"></i>
                </div>
                <p class="text-xs leading-relaxed text-navy-700 sm:text-sm">{t('products.r2.setup')}</p>
