              <div class="flex items-start gap-3 rounded-xl bg-navy-50/50 p-3.5 sm:p-4">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-rose-500/10">
                  <i class="fas fa-shield-virus text-sm text-rose-600"></i>
                </div>
                <p class="text-xs font-medium text-navy-700 sm:text-sm">{t('products.r2.feature2')}</p>
              </div>
              <div class="flex items-start gap-3 rounded-xl bg-navy-50/50 p-3.5 sm:p-4">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-amber-500/10">
                  <i class="fas fa-bolt text-sm text-amber-600"></i>
                </div>
                <p class="text-xs font-medium text-navy-700 sm:text-sm">{t('products.r2.feature3')}</p>
              </div>
              <div class="flex items-start gap-3 rounded-xl bg-navy-50/50 p-3.5 sm:p-4">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-emerald-500/10">
                  <i class="fas fa-key text-sm text-emerald-600"></i>
                </div>
                <p class="text-xs font-medium text-navy-700 sm:text-sm">{t('products.r2.feature4')}</p>
              </div>
