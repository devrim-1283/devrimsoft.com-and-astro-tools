---
import type { Locale } from '@/i18n/locales'
import { useTranslations } from '@/i18n/utils'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section class="relative overflow-hidden bg-white section-padding">
  <!-- Subtle background decoration -->
  <div class="mesh-gradient absolute left-1/4 top-1/3 h-96 w-96 bg-accent-500/5" style="animation-delay: -3s;"></div>
  <div class="mesh-gradient absolute right-1/4 bottom-1/4 h-72 w-72 bg-navy-200/10"></div>

  <!-- Dot pattern -->
  <div class="absolute inset-0 text-navy-900/[0.03] dot-pattern" style="background-size: 40px 40px;"></div>

  <div class="container-wide relative">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Big gradient heading -->
      <h2 class="font-display text-3xl font-bold tracking-tight text-navy-900 sm:text-5xl lg:text-6xl">
        <span class="gradient-text">{t('cta.title')}</span>
      </h2>

      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-navy-600 sm:mt-6 sm:text-xl">
        {t('cta.subtitle')}
      </p>

      <!-- Single bold CTA -->
      <div class="mt-8 sm:mt-12">
        <a href="#contact" class="btn-accent inline-flex w-full justify-center px-8 py-4 text-base shadow-xl shadow-accent-500/20 hover:shadow-2xl hover:shadow-accent-500/30 sm:w-auto sm:px-12 sm:py-5 sm:text-lg">
          <i class="fas fa-paper-plane"></i>
          {t('cta.button')}
        </a>
      </div>

      <!-- Email below -->
      <div class="mt-6 sm:mt-8">
        <a href="mailto:info@devrimsoft.com" class="inline-flex items-center gap-2 text-navy-500 transition-colors hover:text-accent-600">
          <i class="fas fa-envelope text-xs sm:text-sm"></i>
          <span class="text-xs sm:text-sm">info@devrimsoft.com</span>
        </a>
      </div>
    </div>
  </div>
</section>
