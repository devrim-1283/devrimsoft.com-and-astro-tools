---
import type { Locale } from '@/i18n/locales'
import { ROUTE_MAP, SERVICE_SLUGS } from '@/i18n/locales'
import { useTranslations, getServiceDetailPath, getServiceAlternateLinks } from '@/i18n/utils'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumb from '@/components/shared/Breadcrumb.astro'

interface Props {
  lang: Locale
  serviceKey: string
}

const { lang, serviceKey } = Astro.props
const t = useTranslations(lang)

const title = t(`services.${serviceKey}.title`)
const desc = t(`services.${serviceKey}.desc`)

// Long description — support multiple paragraphs (longDesc, longDesc2, longDesc3…)
const longDescParagraphs = [t(`services.${serviceKey}.longDesc`)]
for (let i = 2; i <= 4; i++) {
  const key = `services.${serviceKey}.longDesc${i}`
  const val = t(key)
  if (val !== key) longDescParagraphs.push(val)
}

// Features — support up to 8
const features: string[] = []
for (let i = 1; i <= 8; i++) {
  const key = `services.${serviceKey}.feature${i}`
  const val = t(key)
  if (val !== key) features.push(val)
}

// Included items — optional section (included1…included8)
const includedItems: string[] = []
for (let i = 1; i <= 8; i++) {
  const key = `services.${serviceKey}.included${i}`
  const val = t(key)
  if (val !== key) includedItems.push(val)
}
const hasIncluded = includedItems.length > 0

// Architecture highlights — optional section (arch1…arch6)
const archItems: Array<{ title: string; desc: string }> = []
for (let i = 1; i <= 6; i++) {
  const titleKey = `services.${serviceKey}.arch${i}.title`
  const titleVal = t(titleKey)
  if (titleVal !== titleKey) {
    archItems.push({ title: titleVal, desc: t(`services.${serviceKey}.arch${i}.desc`) })
  }
}
const hasArchitecture = archItems.length > 0

const processSteps = [
  { title: t(`services.${serviceKey}.process1.title`), desc: t(`services.${serviceKey}.process1.desc`) },
  { title: t(`services.${serviceKey}.process2.title`), desc: t(`services.${serviceKey}.process2.desc`) },
  { title: t(`services.${serviceKey}.process3.title`), desc: t(`services.${serviceKey}.process3.desc`) },
  { title: t(`services.${serviceKey}.process4.title`), desc: t(`services.${serviceKey}.process4.desc`) },
]

const timelineValue = t(`services.${serviceKey}.timelineValue`)
const techStack = t(`services.${serviceKey}.techStack`).split(', ')

const contactPath = `/${lang}/${ROUTE_MAP.contact[lang]}/`
const servicesPath = `/${lang}/${ROUTE_MAP.services[lang]}/`

const servicesMeta: Record<string, { icon: string; gradient: string }> = {
  web:        { icon: 'fas fa-globe',                gradient: 'from-blue-500 to-indigo-600' },
  security:   { icon: 'fas fa-shield-halved',        gradient: 'from-rose-500 to-orange-500' },
  mobile:     { icon: 'fas fa-mobile-screen',        gradient: 'from-emerald-500 to-teal-600' },
  api:        { icon: 'fas fa-code',                 gradient: 'from-violet-500 to-purple-600' },
  cloud:      { icon: 'fas fa-cloud',                gradient: 'from-amber-500 to-orange-600' },
  consulting: { icon: 'fas fa-lightbulb',            gradient: 'from-pink-500 to-rose-600' },
  database:   { icon: 'fas fa-database',             gradient: 'from-cyan-500 to-blue-600' },
  pentest:    { icon: 'fas fa-user-secret',          gradient: 'from-red-600 to-rose-700' },
  hotspot:    { icon: 'fas fa-wifi',                 gradient: 'from-sky-500 to-indigo-600' },
  server:     { icon: 'fas fa-server',               gradient: 'from-slate-600 to-zinc-700' },
  hosting:    { icon: 'fas fa-hard-drive',           gradient: 'from-teal-500 to-emerald-600' },
  proxy:      { icon: 'fas fa-route',                gradient: 'from-fuchsia-500 to-purple-700' },
  email:      { icon: 'fas fa-envelope-circle-check', gradient: 'from-orange-500 to-red-600' },
}

const currentMeta = servicesMeta[serviceKey]

const otherServices = Object.keys(servicesMeta)
  .filter(k => k !== serviceKey)
  .sort(() => 0.5 - Math.random())
  .slice(0, 4)

const alternateLinks = getServiceAlternateLinks(serviceKey)
const currentPageId = `service-${serviceKey}`

// Icons for included items
const includedIcons = [
  'fas fa-server', 'fas fa-code-branch', 'fas fa-arrows-rotate', 'fas fa-certificate',
  'fas fa-shield-halved', 'fas fa-user-secret', 'fas fa-headset', 'fas fa-rocket',
]

// Icons for architecture items
const archIcons = [
  'fas fa-layer-group', 'fas fa-credit-card', 'fas fa-cloud', 'fas fa-lock',
  'fas fa-bolt', 'fas fa-code-merge',
]
---

<BaseLayout
  title={title}
  description={desc}
  lang={lang}
  currentPage={currentPageId}
  customAlternateLinks={alternateLinks}
>

  <!-- Service Detail Header -->
  <section class="relative overflow-hidden border-b border-navy-100 bg-gradient-to-b from-navy-50/60 to-white pb-10 pt-6 sm:pb-14 sm:pt-8">
    <div class="absolute right-0 top-0 h-96 w-96 rounded-full bg-accent-500/5 blur-3xl"></div>
    <div class="absolute -left-20 bottom-0 h-56 w-56 rounded-full bg-blue-500/5 blur-3xl"></div>

    <Breadcrumb
      lang={lang}
      items={[
        { label: t('services.page.title'), href: servicesPath },
        { label: title },
      ]}
    />

    <div class="container-wide relative mt-4 sm:mt-6">
      <div class="mx-auto max-w-4xl">
        <div class="flex items-start gap-5 sm:gap-6">
          <div class={`flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br ${currentMeta.gradient} text-white shadow-lg sm:h-16 sm:w-16`}>
            <i class:list={[currentMeta.icon, 'text-xl sm:text-2xl']}></i>
          </div>
          <div class="min-w-0 flex-1">
            <h1 class="font-display text-2xl font-bold text-navy-900 sm:text-3xl lg:text-4xl">{title}</h1>
            <p class="mt-3 text-base leading-relaxed text-navy-600 sm:text-lg">{desc}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Long Description -->
  <section class="section-padding relative overflow-hidden bg-white">
    <div class="container-wide relative">
      <div class="mx-auto max-w-4xl space-y-5">
        {longDescParagraphs.map((paragraph) => (
          <p class="text-base leading-relaxed text-navy-700 sm:text-lg">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Features -->
  <section class="section-padding relative bg-gradient-to-b from-navy-50/40 to-white">
    <div class="container-wide relative">
      <h2 class="heading-3 text-center text-navy-900">{t('services.detail.featuresTitle')}</h2>
      <div class:list={[
        'mt-8 grid gap-4 sm:mt-12 sm:grid-cols-2',
        features.length > 4 ? 'lg:grid-cols-4' : `lg:grid-cols-${features.length}`,
      ]}>
        {features.map((feature) => (
          <div class="rounded-xl border border-navy-100 bg-white p-5 transition-all duration-200 hover:border-navy-200 hover:shadow-lg sm:p-6">
            <div class="flex items-start gap-3">
              <div class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-accent-500/10">
                <i class="fas fa-check text-xs text-accent-600"></i>
              </div>
              <span class="text-sm font-medium leading-relaxed text-navy-800 sm:text-[15px]">{feature}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included — only rendered when included keys exist -->
  {hasIncluded && (
    <section class="section-padding relative overflow-hidden bg-white">
      <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-accent-500/5 blur-3xl"></div>
      <div class="container-wide relative">
        <div class="text-center">
          <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-accent-200 bg-accent-50 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-accent-700 sm:mb-4 sm:text-xs">
            <i class="fas fa-gift text-accent-500"></i>
            {t('services.detail.includedTitle')}
          </div>
          <h2 class="heading-3 text-navy-900">{t('services.detail.includedTitle')}</h2>
        </div>
        <div class="mx-auto mt-8 grid max-w-5xl gap-4 sm:mt-12 sm:grid-cols-2 lg:grid-cols-4">
          {includedItems.map((item, i) => (
            <div class="group flex items-center gap-3.5 rounded-xl border border-navy-100 bg-gradient-to-br from-white to-navy-50/50 p-4 transition-all duration-200 hover:border-accent-300 hover:shadow-lg sm:p-5">
              <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-accent-500/10 transition-colors group-hover:bg-accent-500/20">
                <i class:list={[includedIcons[i] ?? 'fas fa-check', 'text-sm text-accent-600']}></i>
              </div>
              <span class="text-sm font-semibold leading-snug text-navy-800">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Process Steps Timeline -->
  <section class="section-padding relative overflow-hidden bg-gradient-to-b from-navy-50/40 to-white">
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-blue-500/5 blur-3xl"></div>
    <div class="container-wide relative">
      <h2 class="heading-3 text-center text-navy-900">{t('services.detail.processTitle')}</h2>

      <div class="mx-auto mt-8 max-w-4xl sm:mt-12">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {processSteps.map((step, index) => (
            <div class="relative">
              <div class="flex flex-col items-center text-center">
                <div class={`flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br ${currentMeta.gradient} text-lg font-bold text-white shadow-lg`}>
                  {index + 1}
                </div>
                <h3 class="mt-4 text-sm font-bold text-navy-900 sm:text-base">{step.title}</h3>
                <p class="mt-2 text-xs leading-relaxed text-navy-600 sm:text-sm">{step.desc}</p>
              </div>
              {index < processSteps.length - 1 && (
                <div class="absolute right-0 top-6 hidden h-0.5 w-full -translate-x-1/2 bg-gradient-to-r from-navy-200 to-transparent lg:block" style={`left: calc(100% + 0.75rem); width: calc(100% - 3rem);`}></div>
              )}
            </div>
          ))}
        </div>

        <!-- Timeline Value -->
        <div class="mt-8 flex items-center justify-center gap-3 sm:mt-12">
          <div class="flex items-center gap-2 rounded-full border border-navy-200 bg-white px-5 py-2.5 shadow-sm">
            <i class="fas fa-clock text-sm text-accent-500"></i>
            <span class="text-sm font-semibold text-navy-700">{t('services.detail.timeline')}:</span>
            <span class="text-sm font-bold text-accent-600">{timelineValue}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Architecture — only rendered when arch keys exist -->
  {hasArchitecture && (
    <section class="section-padding relative overflow-hidden bg-gradient-to-br from-navy-800 via-navy-900 to-navy-950">
      <div class="absolute -right-20 top-10 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
      <div class="absolute -left-20 bottom-0 h-56 w-56 rounded-full bg-accent-500/8 blur-3xl"></div>
      <div class="absolute inset-0 text-white/[0.02] dot-pattern"></div>

      <div class="container-wide relative">
        <div class="text-center">
          <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-navy-600 bg-navy-800 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-navy-300 sm:mb-4 sm:text-xs">
            <i class="fas fa-microchip text-accent-400"></i>
            {t('services.detail.architectureTitle')}
          </div>
          <h2 class="heading-3 text-white">{t('services.detail.architectureTitle')}</h2>
        </div>

        <div class="mx-auto mt-8 grid max-w-5xl gap-5 sm:mt-12 sm:grid-cols-2">
          {archItems.map((item, i) => (
            <div class="group rounded-2xl border border-navy-700/60 bg-navy-800/40 p-6 backdrop-blur-sm transition-all duration-300 hover:border-navy-600 hover:bg-navy-800/60">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-accent-500/20 to-accent-600/10 transition-colors group-hover:from-accent-500/30 group-hover:to-accent-600/20">
                  <i class:list={[archIcons[i] ?? 'fas fa-cog', 'text-lg text-accent-400']}></i>
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="text-base font-bold text-white sm:text-lg">{item.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-navy-300">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Tech Stack -->
  <section class:list={[
    'section-padding relative',
    hasArchitecture ? 'bg-white' : 'bg-gradient-to-b from-navy-50/40 to-white',
  ]}>
    <div class="container-wide relative">
      <h2 class="heading-3 text-center text-navy-900">{t('services.detail.techTitle')}</h2>
      <div class="mx-auto mt-8 flex max-w-3xl flex-wrap items-center justify-center gap-3">
        {techStack.map((tech) => (
          <span class="rounded-lg border border-navy-200 bg-white px-4 py-2 text-sm font-medium text-navy-700 shadow-sm transition-all duration-200 hover:border-accent-500 hover:text-accent-600">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding relative overflow-hidden bg-gradient-to-br from-navy-800 via-navy-900 to-navy-950">
    <div class="absolute -right-20 top-10 h-72 w-72 rounded-full bg-accent-500/10 blur-3xl"></div>
    <div class="absolute -left-20 bottom-0 h-56 w-56 rounded-full bg-navy-600/20 blur-3xl"></div>
    <div class="absolute inset-0 text-white/[0.03] dot-pattern"></div>

    <div class="container-wide relative text-center">
      <h2 class="heading-2 text-white">{t('services.detail.ctaTitle')}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-navy-300 sm:text-lg">{t('services.detail.ctaDesc')}</p>
      <a
        href={contactPath}
        class="mt-8 inline-flex items-center gap-2 rounded-xl bg-accent-500 px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-accent-500/25 transition-all duration-200 hover:bg-accent-600 hover:shadow-xl hover:shadow-accent-500/30 sm:text-base"
      >
        {t('services.detail.ctaButton')}
        <i class="fas fa-arrow-right text-xs"></i>
      </a>
    </div>
  </section>

  <!-- Other Services -->
  <section class="section-padding relative bg-white">
    <div class="container-wide relative">
      <h2 class="heading-3 text-center text-navy-900">{t('services.detail.otherServices')}</h2>
      <div class="mt-8 grid gap-4 sm:mt-12 sm:grid-cols-2 lg:grid-cols-4">
        {otherServices.map((key) => {
          const meta = servicesMeta[key]
          return (
            <a
              href={getServiceDetailPath(lang, key)}
              class="group rounded-xl border border-navy-100 bg-white p-5 transition-all duration-200 hover:border-navy-200 hover:shadow-lg hover:-translate-y-1 sm:p-6"
            >
              <div class="flex items-start gap-4">
                <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br ${meta.gradient} text-white shadow-md transition-transform duration-300 group-hover:scale-110`}>
                  <i class:list={[meta.icon, 'text-sm']}></i>
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="text-sm font-bold text-navy-900 sm:text-base">{t(`services.${key}.title`)}</h3>
                  <p class="mt-1.5 line-clamp-2 text-xs leading-relaxed text-navy-600">{t(`services.${key}.desc`)}</p>
                </div>
              </div>
              <div class="mt-3 flex items-center gap-1.5 text-xs font-semibold text-accent-600">
                <span>{t('services.detail.viewDetails')}</span>
                <i class="fas fa-arrow-right text-[9px] transition-transform group-hover:translate-x-1"></i>
              </div>
            </a>
          )
        })}
      </div>

      <!-- Back to all services -->
      <div class="mt-8 text-center sm:mt-12">
        <a
          href={servicesPath}
          class="inline-flex items-center gap-2 text-sm font-semibold text-navy-600 transition-colors hover:text-accent-600"
        >
          <i class="fas fa-arrow-left text-xs"></i>
          {t('services.detail.backToServices')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
