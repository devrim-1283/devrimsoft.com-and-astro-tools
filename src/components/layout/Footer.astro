---
import type { Locale } from '@/i18n/locales'
import { useTranslations } from '@/i18n/utils'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)
const currentYear = new Date().getFullYear()

const quickLinks = [
  { key: 'about', label: t('nav.about'), icon: 'fas fa-building' },
  { key: 'portfolio', label: t('nav.portfolio'), icon: 'fas fa-briefcase' },
  { key: 'certifications', label: t('nav.certifications'), icon: 'fas fa-certificate' },
  { key: 'contact', label: t('nav.contact'), icon: 'fas fa-envelope' },
]

const serviceLinks = [
  { label: t('services.web.title'), icon: 'fas fa-globe' },
  { label: t('services.security.title'), icon: 'fas fa-shield-halved' },
  { label: t('services.mobile.title'), icon: 'fas fa-mobile-screen' },
  { label: t('services.api.title'), icon: 'fas fa-code' },
  { label: t('services.cloud.title'), icon: 'fas fa-cloud' },
  { label: t('services.consulting.title'), icon: 'fas fa-lightbulb' },
  { label: t('services.pentest.title'), icon: 'fas fa-user-secret' },
  { label: t('services.hotspot.title'), icon: 'fas fa-wifi' },
]
---

<footer class="relative overflow-hidden border-t border-navy-200 bg-white text-navy-600">
  <!-- Subtle gradient orb -->
  <div class="absolute -right-32 -top-32 h-64 w-64 rounded-full bg-accent-500/5 blur-3xl"></div>
  <div class="absolute -left-32 bottom-0 h-48 w-48 rounded-full bg-navy-200/10 blur-3xl"></div>

  <div class="container-wide relative section-padding">
    <div class="grid gap-10 sm:gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2">
          <div class="flex h-10 w-auto items-center text-navy-800 transition-colors duration-200 sm:h-14">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 698" fill="currentColor" class="h-8 w-auto sm:h-12">
              <g transform="translate(0,698) scale(0.1,-0.1)" stroke="none">
                <path d="M7570 5180 c-448 -71 -752 -383 -810 -831 -5 -41 -10 -278 -10 -527 l0 -454 -67 70 c-201 207 -475 275 -749 188 -83 -27 -185 -85 -241 -139 -43 -40 -42 -21 3 61 58 106 92 152 169 227 136 134 245 180 425 179 97 0 128 -5 200 -28 47 -16 99 -36 116 -47 17 -10 33 -17 35 -15 2 2 2 34 1 71 -4 77 8 69 -177 122 -269 76 -568 47 -828 -83 -118 -59 -202 -122 -303 -226 -150 -155 -243 -323 -296 -540 -20 -80 -23 -118 -22 -268 0 -157 3 -185 27 -275 26 -97 109 -283 158 -355 129 -190 276 -314 490 -414 295 -138 658 -137 955 4 366 173 594 478 659 881 7 45 8 1259 1 1266 -9 9 -68 -31 -90 -60 -21 -28 -21 -39 -27 -615 -6 -621 -7 -627 -57 -772 -84 -240 -287 -467 -517 -576 -124 -58 -175 -74 -266 -81 -240 -18 -487 130 -631 379 -26 45 -46 84 -43 86 3 3 35 -15 73 -40 86 -58 129 -79 217 -109 61 -21 88 -24 205 -23 120 1 143 4 209 27 193 69 333 188 420 357 71 136 73 150 82 585 4 215 12 415 18 446 16 81 72 226 113 290 46 70 140 157 215 199 247 138 296 172 374 258 118 131 190 332 191 532 0 87 -24 226 -42 244 -13 13 -112 17 -180 6z m95 -205 c19 -156 -43 -358 -147 -483 -59 -71 -133 -125 -281 -207 -70 -38 -152 -91 -183 -117 -52 -45 -137 -140 -163 -183 -20 -34 -8 384 13 460 48 172 126 306 238 411 56 53 241 164 253 152 2 -2 -19 -33 -47 -68 -98 -125 -158 -298 -158 -454 0 -52 4 -86 10 -86 18 0 88 48 104 72 9 12 16 37 16 55 0 132 86 320 189 411 39 35 124 92 137 92 7 0 15 -24 19 -55z m-1901 -1127 c-158 -167 -252 -365 -305 -643 -18 -91 -18 -404 0 -509 14 -88 55 -227 95 -324 39 -98 130 -228 227 -324 48 -49 87 -88 86 -88 -9 0 -124 48 -169 70 -97 48 -169 100 -249 180 -100 100 -151 171 -211 295 -108 228 -133 468 -72 702 20 78 88 234 129 298 82 128 210 250 355 335 53 32 156 79 174 80 5 0 -22 -33 -60 -72z m496 -318 c137 -18 286 -109 375 -231 78 -105 115 -218 115 -350 0 -110 -14 -173 -61 -268 -57 -115 -145 -202 -260 -259 -98 -47 -161 -62 -264 -62 -96 0 -164 15 -250 54 -164 75 -288 229 -330 409 -75 317 162 665 480 707 84 11 110 11 195 0z"/>
              </g>
            </svg>
          </div>
          <span class="font-display text-xl font-bold text-navy-900 sm:text-3xl">Devrim<span class="text-accent-500">Soft</span></span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-navy-500 sm:mt-5">{t('footer.description')}</p>

        <!-- TEKMER Badge -->
        <div class="mt-4 inline-flex items-center gap-2 rounded-lg border border-navy-200 bg-navy-50/50 px-3 py-2 text-xs text-navy-500 sm:mt-5">
          <i class="fas fa-building-columns text-accent-500"></i>
          <span>{t('footer.tekmer')}</span>
        </div>

        <!-- Social Links -->
        <div class="mt-4 flex items-center gap-2.5 sm:mt-5 sm:gap-3">
          <a href="https://github.com/devrim-1283" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-lg border border-navy-200 text-navy-400 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white sm:h-9 sm:w-9" aria-label="GitHub">
            <i class="fab fa-github text-sm"></i>
          </a>
          <a href="https://www.linkedin.com/company/110658134/" target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-lg border border-navy-200 text-navy-400 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white sm:h-9 sm:w-9" aria-label="LinkedIn">
            <i class="fab fa-linkedin-in text-sm"></i>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-navy-900">{t('footer.quickLinks')}</h3>
        <ul class="mt-4 space-y-2.5 sm:mt-5 sm:space-y-3">
          {quickLinks.map(({ key, label, icon }) => (
            <li>
              <a href={`#${key}`} class="group flex items-center gap-2.5 py-0.5 text-sm text-navy-500 transition-colors hover:text-navy-900">
                <i class:list={[icon, 'w-4 text-center text-xs text-navy-400 transition-colors group-hover:text-accent-500']}></i>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-navy-900">{t('footer.services')}</h3>
        <ul class="mt-4 space-y-2.5 sm:mt-5 sm:space-y-3">
          {serviceLinks.map(({ label, icon }) => (
            <li>
              <a href="#services" class="group flex items-center gap-2.5 py-0.5 text-sm text-navy-500 transition-colors hover:text-navy-900">
                <i class:list={[icon, 'w-4 text-center text-xs text-navy-400 transition-colors group-hover:text-accent-500']}></i>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-navy-900">{t('nav.contact')}</h3>
        <ul class="mt-4 space-y-3 text-sm sm:mt-5 sm:space-y-4">
          <li>
            <a href="mailto:info@devrimsoft.com" class="group flex items-center gap-2.5 text-navy-500 transition-colors hover:text-navy-900">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-navy-50">
                <i class="fas fa-envelope text-xs text-navy-400 transition-colors group-hover:text-accent-500"></i>
              </div>
              info@devrimsoft.com
            </a>
          </li>
          <li class="flex items-center gap-2.5 text-navy-500">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-navy-50">
              <i class="fas fa-location-dot text-xs text-navy-400"></i>
            </div>
            Antalya / Alanya (TEKMER)
          </li>
          <li class="flex items-center gap-2.5 text-navy-500">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-navy-50">
              <i class="fas fa-location-dot text-xs text-navy-400"></i>
            </div>
            Istanbul
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-navy-200 pt-6 sm:mt-16 sm:flex-row sm:pt-8">
      <p class="text-xs text-navy-400 sm:text-sm">&copy; {currentYear} DevrimSoft. {t('footer.rights')}</p>
      <div class="flex flex-col items-center gap-3 sm:items-end">
        <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4">
          <a href="https://bug.devrimsoft.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-navy-200 px-3 py-1.5 text-xs font-medium text-navy-500 transition-all duration-200 hover:border-accent-500 hover:text-accent-600">
            <i class="fas fa-bug text-[10px]"></i>
            {t('footer.reportBug')}
          </a>
          <div class="flex items-center gap-1.5 text-xs text-navy-400 sm:text-sm">
            <i class="fas fa-heart text-xs text-red-500"></i>
            <span>{t('footer.craftedWith')}</span>
          </div>
        </div>
        <div class="flex items-center gap-2 text-[11px] italic text-navy-400 sm:text-xs">
          <span>"{t('footer.quote')}"</span>
          <span class="not-italic font-semibold text-navy-500">— M. Kemal Atatürk</span>
        </div>
      </div>
    </div>
  </div>
</footer>
