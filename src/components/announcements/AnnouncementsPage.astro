---
import type { Locale } from '@/i18n/locales'
import { useTranslations } from '@/i18n/utils'
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHeader from '@/components/shared/PageHeader.astro'
import ScrollReveal from '@/components/shared/ScrollReveal.astro'
import CTASection from '@/components/home/CTASection.astro'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)

const tagLabels: Record<string, Record<string, string>> = {
  launch: { tr: 'Lansman', en: 'Launch', ru: 'Запуск', uk: 'Запуск', de: 'Launch', es: 'Lanzamiento', fr: 'Lancement' },
  partnership: { tr: 'Ortaklik', en: 'Partnership', ru: 'Партнёрство', uk: 'Партнерство', de: 'Partnerschaft', es: 'Asociacion', fr: 'Partenariat' },
  certification: { tr: 'Sertifika', en: 'Certification', ru: 'Сертификация', uk: 'Сертифiкацiя', de: 'Zertifizierung', es: 'Certificacion', fr: 'Certification' },
}

const announcements = [
  {
    titleKey: 'announcements.item1.title',
    descKey: 'announcements.item1.desc',
    dateKey: 'announcements.item1.date',
    icon: 'fas fa-rocket',
    gradient: 'from-accent-500 to-amber-600',
    tagKey: 'launch',
  },
  {
    titleKey: 'announcements.item2.title',
    descKey: 'announcements.item2.desc',
    dateKey: 'announcements.item2.date',
    icon: 'fas fa-handshake',
    gradient: 'from-blue-500 to-indigo-600',
    tagKey: 'partnership',
  },
  {
    titleKey: 'announcements.item3.title',
    descKey: 'announcements.item3.desc',
    dateKey: 'announcements.item3.date',
    icon: 'fas fa-shield-halved',
    gradient: 'from-emerald-500 to-teal-600',
    tagKey: 'certification',
  },
]
---

<BaseLayout
  title={t('announcements.title')}
  description={t('announcements.subtitle')}
  lang={lang}
  currentPage="announcements"
>
  <PageHeader title={t('announcements.title')} subtitle={t('announcements.subtitle')} />

  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="mx-auto max-w-3xl space-y-8">
        {announcements.map((item, index) => (
          <ScrollReveal>
            <article class="group relative overflow-hidden rounded-2xl border border-navy-100 bg-white transition-all duration-300 hover:border-navy-200 hover:shadow-xl hover:shadow-navy-100/50">
              <div class="flex flex-col sm:flex-row">
                {/* Icon column */}
                <div class={`flex items-center justify-center bg-gradient-to-br ${item.gradient} p-8 sm:w-32 sm:flex-shrink-0`}>
                  <i class:list={[item.icon, 'text-3xl text-white/90']}></i>
                </div>

                {/* Content */}
                <div class="flex-1 p-6 sm:p-8">
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700">
                      <i class="fas fa-tag text-[10px] text-accent-500"></i>
                      {tagLabels[item.tagKey][lang]}
                    </span>
                    <span class="inline-flex items-center gap-1.5 text-xs text-navy-500">
                      <i class="far fa-calendar text-[10px]"></i>
                      {t(item.dateKey)}
                    </span>
                  </div>

                  <h2 class="mt-4 font-display text-xl font-bold text-navy-900 transition-colors group-hover:text-accent-600">
                    {t(item.titleKey)}
                  </h2>

                  <p class="mt-3 text-sm leading-relaxed text-navy-600">
                    {t(item.descKey)}
                  </p>
                </div>
              </div>

              {/* Hover accent line */}
              <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-gradient-to-r from-accent-400 to-accent-600 transition-all duration-500 group-hover:w-full"></div>
            </article>
          </ScrollReveal>
        ))}
      </div>

      <!-- Stay tuned -->
      <ScrollReveal>
        <div class="mx-auto mt-16 max-w-3xl rounded-2xl border border-dashed border-navy-200 bg-navy-50/50 p-8 text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-accent-500/10">
            <i class="fas fa-bell text-xl text-accent-500"></i>
          </div>
          <p class="mt-4 text-navy-600">{t('announcements.stayTuned')}</p>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <CTASection lang={lang} />
</BaseLayout>
