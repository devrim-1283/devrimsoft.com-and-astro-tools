---
import type { Locale } from '@/i18n/locales'
import { useTranslations } from '@/i18n/utils'
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHeader from '@/components/shared/PageHeader.astro'
import ScrollReveal from '@/components/shared/ScrollReveal.astro'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)

const contactInfo = [
  {
    icon: 'fas fa-envelope',
    label: 'E-mail',
    value: 'info@devrimsoft.com',
    href: 'mailto:info@devrimsoft.com',
    gradient: 'from-accent-500 to-amber-600',
  },
  {
    icon: 'fas fa-location-dot',
    label: t('contact.info.address'),
    value: t('contact.info.address'),
    href: null,
    gradient: 'from-blue-500 to-indigo-600',
  },
  {
    icon: 'fas fa-clock',
    label: t('contact.info.hoursLabel'),
    value: t('contact.info.hours'),
    href: null,
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    icon: 'fas fa-bolt',
    label: t('contact.info.responseTime'),
    value: t('contact.info.responseTime'),
    href: null,
    gradient: 'from-violet-500 to-purple-600',
  },
]
---

<BaseLayout
  title={t('contact.title')}
  description={t('contact.subtitle')}
  lang={lang}
  currentPage="contact"
>
  <PageHeader title={t('contact.title')} subtitle={t('contact.subtitle')} />

  <section class="section-padding bg-white">
    <div class="container-wide">
      <div class="grid gap-8 sm:gap-12 lg:grid-cols-5">
        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <ScrollReveal>
            <div class="rounded-2xl border border-navy-100 bg-white p-5 shadow-sm sm:p-8 lg:p-10">
              <form class="space-y-5 sm:space-y-6" data-contact-form>
                <!-- Name -->
                <div>
                  <label for="name" class="mb-1.5 block text-sm font-medium text-navy-800 sm:mb-2">
                    <i class="fas fa-user mr-2 text-xs text-navy-400"></i>
                    {t('contact.form.name')}
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full rounded-xl border border-navy-200 bg-navy-50/30 px-4 py-3 text-sm text-navy-900 transition-all duration-200 placeholder:text-navy-400 focus:border-accent-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-accent-500/20"
                    placeholder={t('contact.form.name')}
                  />
                </div>

                <!-- Email -->
                <div>
                  <label for="email" class="mb-1.5 block text-sm font-medium text-navy-800 sm:mb-2">
                    <i class="fas fa-at mr-2 text-xs text-navy-400"></i>
                    {t('contact.form.email')}
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full rounded-xl border border-navy-200 bg-navy-50/30 px-4 py-3 text-sm text-navy-900 transition-all duration-200 placeholder:text-navy-400 focus:border-accent-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-accent-500/20"
                    placeholder={t('contact.form.email')}
                  />
                </div>

                <!-- Subject -->
                <div>
                  <label for="subject" class="mb-1.5 block text-sm font-medium text-navy-800 sm:mb-2">
                    <i class="fas fa-tag mr-2 text-xs text-navy-400"></i>
                    {t('contact.form.subject')}
                  </label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    class="w-full rounded-xl border border-navy-200 bg-navy-50/30 px-4 py-3 text-sm text-navy-900 transition-all duration-200 placeholder:text-navy-400 focus:border-accent-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-accent-500/20"
                    placeholder={t('contact.form.subject')}
                  />
                </div>

                <!-- Message -->
                <div>
                  <label for="message" class="mb-1.5 block text-sm font-medium text-navy-800 sm:mb-2">
                    <i class="fas fa-comment mr-2 text-xs text-navy-400"></i>
                    {t('contact.form.message')}
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    required
                    class="w-full resize-none rounded-xl border border-navy-200 bg-navy-50/30 px-4 py-3 text-sm text-navy-900 transition-all duration-200 placeholder:text-navy-400 focus:border-accent-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-accent-500/20"
                    placeholder={t('contact.form.message')}
                  ></textarea>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-accent w-full py-3.5 text-sm sm:py-4 sm:text-base">
                  <i class="fas fa-paper-plane text-xs sm:text-sm"></i>
                  {t('contact.form.send')}
                </button>
              </form>
            </div>
          </ScrollReveal>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <ScrollReveal>
            <div class="mb-5 sm:mb-6">
              <h2 class="font-display text-lg font-bold text-navy-900 sm:text-xl">{t('contact.info.title')}</h2>
            </div>
          </ScrollReveal>

          <div class="space-y-3 sm:space-y-4">
            {contactInfo.map((info) => (
              <ScrollReveal>
                <div class="group flex items-start gap-3 rounded-2xl border border-navy-100 bg-white p-4 transition-all duration-300 hover:border-navy-200 hover:shadow-lg hover:-translate-y-0.5 sm:gap-4 sm:p-5">
                  <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-gradient-to-br ${info.gradient} text-white shadow-sm transition-transform duration-300 group-hover:scale-110 sm:h-11 sm:w-11`}>
                    <i class:list={[info.icon, 'text-sm']}></i>
                  </div>
                  <div>
                    <div class="text-[11px] font-medium uppercase tracking-wider text-navy-500 sm:text-xs">{info.label}</div>
                    {info.href ? (
                      <a href={info.href} class="mt-0.5 block text-sm font-semibold text-navy-800 transition-colors hover:text-accent-600 sm:mt-1">
                        {info.value}
                      </a>
                    ) : (
                      <div class="mt-0.5 text-sm font-semibold text-navy-800 sm:mt-1">{info.value}</div>
                    )}
                  </div>
                </div>
              </ScrollReveal>
            ))}
          </div>

          <!-- Social -->
          <ScrollReveal>
            <div class="mt-6 rounded-2xl border border-navy-100 bg-gradient-to-br from-navy-50/80 to-white p-5 sm:mt-8 sm:p-6">
              <h3 class="text-sm font-semibold text-navy-800">Social</h3>
              <div class="mt-3 flex items-center gap-2.5 sm:mt-4 sm:gap-3">
                <a href="#" class="flex h-10 w-10 items-center justify-center rounded-xl border border-navy-200 text-navy-500 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white" aria-label="GitHub">
                  <i class="fab fa-github"></i>
                </a>
                <a href="#" class="flex h-10 w-10 items-center justify-center rounded-xl border border-navy-200 text-navy-500 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white" aria-label="LinkedIn">
                  <i class="fab fa-linkedin-in"></i>
                </a>
                <a href="#" class="flex h-10 w-10 items-center justify-center rounded-xl border border-navy-200 text-navy-500 transition-all duration-200 hover:border-accent-500 hover:bg-accent-500 hover:text-white" aria-label="X / Twitter">
                  <i class="fab fa-x-twitter"></i>
                </a>
              </div>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
